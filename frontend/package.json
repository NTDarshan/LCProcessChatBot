{
  "name": "mi",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "dev-build": "ng build --configuration=dev --base-href /mi --deploy-url /mi/ --output-hashing=all",
    "production-build": "ng build --configuration production --base-href /mi  --deploy-url /mi/ --aot --output-hashing=all",
