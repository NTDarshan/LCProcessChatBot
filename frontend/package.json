    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.4",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@azure/msal-angular": "^4.0.23",
    "@azure/msal-browser": "^4.27.0",
    "@microsoft/signalr": "^10.0.0",
    "bootstrap": "^5.3.8",
    "chart.js": "^4.5.1",
    "moment": "^2.30.1",
    "ngx-toastr": "^19.1.0",
    "rxjs": "~7.8.0",
